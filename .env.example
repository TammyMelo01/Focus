NEXT_PUBLIC_APP_URL=http://localhost:3000

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
